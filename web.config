<?xml version="1.0" encoding="utf-8"?>
<!--
  Test file for ASP.NET web.config ViewState vulnerability detection
  These are GLOBAL settings that affect ALL pages in the application
-->
<configuration>
  <system.web>

    <!-- CRITICAL [deser]: Global ViewState MAC Disabled -->
    <pages enableViewStateMac="false" validateRequest="false" />

    <!-- CRITICAL [deser]: MachineKey validation disabled -->
    <machineKey validation="None" decryption="Auto" />

    <!-- Alternative dangerous machineKey patterns -->
    <!-- <machineKey validationKey="AutoGenerate,IsolateApps" validation="SHA1" /> -->

    <!-- HIGH [auth]: Custom errors off exposes stack traces -->
    <customErrors mode="Off" />

    <!-- HIGH: Debug mode in production -->
    <compilation debug="true" targetFramework="4.8" />

    <!-- MEDIUM: Cookieless sessions enable session fixation -->
    <sessionState cookieless="true" timeout="30" />

    <!-- HIGH: Forms auth without secure cookies -->
    <authentication mode="Forms">
      <forms loginUrl="~/Login.aspx"
             protection="None"
             requireSSL="false"
             cookieless="UseUri" />
    </authentication>

    <!-- Request validation disabled globally -->
    <httpRuntime requestValidationMode="2.0" />

  </system.web>

  <system.webServer>
    <!-- Directory browsing enabled -->
    <directoryBrowse enabled="true" />

    <!-- Custom headers exposing server info -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Powered-By" value="ASP.NET" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>

</configuration>
